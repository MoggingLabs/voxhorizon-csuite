# =============================================================================
# Vox Horizon C-Suite - isolated stack environment (Hermes runtime)
# -----------------------------------------------------------------------------
# Lives on the VPS at /home/csuite/.config/voxhorizon-csuite/csuite.env
# (chmod 600, owned by csuite). NEVER commit a filled copy. This .example is the
# only version that belongs in the repo.
#
# bootstrap-csuite.sh generates the Supabase secrets. You provide the Codex auth.
# OpenAI is reached via the Codex OAuth subscription (auth.json), NOT env keys:
# there is deliberately NO OPENAI_API_KEY and NO OPENROUTER_API_KEY here.
# Interface is Mission Control ONLY - no Telegram, no Slack.
# =============================================================================

# ---------------------------------------------------------------------------
# Self-hosted Supabase (generated by bootstrap; mirrored into supabase-src/docker/.env)
# ---------------------------------------------------------------------------
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
POSTGRES_PASSWORD=
JWT_SECRET=
SUPABASE_DASHBOARD_USERNAME=csuite
SUPABASE_DASHBOARD_PASSWORD=
SUPABASE_NETWORK=csuite-supabase_default

# ---------------------------------------------------------------------------
# Data Brain dashboard
# ---------------------------------------------------------------------------
DASHBOARD_AUTH_PASS=
DASHBOARD_AUTH_SECRET=
OPERATOR_EMAIL=diogosilvaenterprise@gmail.com
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3100
# Business integrations start EMPTY (mock mode). Light up later, one at a time.

# ---------------------------------------------------------------------------
# Hermes C-Suite agents
# ---------------------------------------------------------------------------
# Model: OpenAI via the ChatGPT/Codex OAuth SUBSCRIPTION ONLY.
#   - NO OPENAI_API_KEY, NO OPENROUTER_API_KEY (do not add them).
#   - Auth is a Codex auth.json placed in each agent's data dir
#     (/opt/voxhorizon-csuite/agents/<name>/data/auth.json, mounted to
#     $HERMES_HOME=/opt/data). Do a Codex/ChatGPT login once and copy it in.
# CODEX_AUTH_JSON_SRC = host path to the auth.json the bootstrap/sync copies in.
CODEX_AUTH_JSON_SRC=/home/csuite/.config/voxhorizon-csuite/codex-auth.json

# Agents are PASSIVE containers (no channel). Mission Control's dispatcher drives
# them via `docker exec csuite-hermes-<name> hermes chat`. No Telegram/Slack vars.

# ---------------------------------------------------------------------------
# Mission Control (the sole interface) + dispatcher
# ---------------------------------------------------------------------------
# Bearer the MC dashboard uses to call the dispatcher service.
CSUITE_DISPATCHER_SECRET=
# Mission Control dashboard single-operator auth gate.
MC_AUTH_PASS=
MC_AUTH_SECRET=

# ---------------------------------------------------------------------------
# Data-Brain read MCP server (used by every C-Suite agent to query business data)
# ---------------------------------------------------------------------------
# Direct read-only Postgres DSN into the self-hosted Supabase DB. bootstrap can
# create a SELECT-only role; until then point at the supabase db service.
# Reachable from the agent containers over csuite_net (supabase db service name).
CSUITE_DB_DSN=postgresql://csuite_readonly:CHANGE_ME@db:5432/postgres
